generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== NextAuth Models ==========

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  nome          String?
  cognome       String?
  image         String?
  companyId     String?
  ruolo         String    @default("admin")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company  Company?  @relation(fields: [companyId], references: [id])
  accounts Account[]
  sessions Session[]

  @@index([companyId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ========== Business Models ==========

model Company {
  id                  String   @id @default(cuid())
  nome                String
  indirizzo           String
  citta               String
  cap                 String
  piva                String   @unique
  telefono            String?
  email               String?
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users    User[]
  drivers  Driver[]
  vehicles Vehicle[]
  orders   Order[]
  trips    Trip[]
  partners Partner[]
  settings Setting[]
}

model Driver {
  id                    String       @id @default(cuid())
  companyId             String
  nome                  String
  cognome               String
  codiceFiscale         String       @unique
  patenteTipo           String       // B, C, CE, etc.
  patenteNumero         String
  patenteScadenza       DateTime
  cartaCQC              String?
  cqcScadenza           DateTime?
  tachigrafoScadenza    DateTime
  oreGuidaSettimana     Float        @default(0)
  oreRiposoRimanenti    Float        @default(11)
  stato                 DriverStatus @default(disponibile)
  telefono              String?
  latitudine            Float?
  longitudine           Float?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  trips   Trip[]

  @@index([companyId])
  @@index([stato])
}

enum DriverStatus {
  disponibile
  in_viaggio
  riposo
  non_disponibile
}

model Vehicle {
  id               String        @id @default(cuid())
  companyId        String
  targa            String        @unique
  tipo             VehicleType
  marca            String
  modello          String
  anno             Int
  capacitaPesoKg   Float
  capacitaVolumeM3 Float
  consumoKmL       Float?        // consumo carburante km/litro
  stato            VehicleStatus @default(disponibile)
  kmAttuali        Int           @default(0)
  prossimaRevisione DateTime?
  prossimaManutenzione DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  trips        Trip[]
  maintenances Maintenance[]

  @@index([companyId])
  @@index([stato])
}

enum VehicleType {
  furgone
  camion
  furgone_frigo
  cisterna
  pianale
}

enum VehicleStatus {
  disponibile
  in_uso
  manutenzione
}

model Order {
  id                 String      @id @default(cuid())
  companyId          String
  codiceOrdine       String      @unique
  mittenteNome       String
  mittenteIndirizzo  String
  mittenteCitta      String
  mittenteCAP        String
  mittenteLat        Float?
  mittenteLng        Float?
  destinatarioNome   String
  destinatarioIndirizzo String
  destinatarioCitta  String
  destinatarioCAP    String
  destinatarioLat    Float?
  destinatarioLng    Float?
  tipoMerce          String
  merceRefrigerata   Boolean     @default(false)
  mercePericolosa    Boolean     @default(false)
  pesoKg             Float
  volumeM3           Float
  urgenza            Urgenza     @default(normale)
  finestraCaricoDa   DateTime
  finestraCaricoA    DateTime
  finestraConsegnaDa DateTime
  finestraConsegnaA  DateTime
  note               String?
  stato              OrderStatus @default(pending)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  company  Company     @relation(fields: [companyId], references: [id])
  tripId   String?
  trip     Trip?       @relation(fields: [tripId], references: [id])

  @@index([companyId])
  @@index([stato])
  @@index([urgenza])
}

enum Urgenza {
  normale
  urgente
  programmato
}

enum OrderStatus {
  pending
  assegnato
  in_corso
  completato
  annullato
}

model Trip {
  id                    String     @id @default(cuid())
  companyId             String
  driverId              String
  vehicleId             String
  routeDataJson         Json?
  kmTotali              Float?
  tempoStimatoMinuti    Int?
  costoCarburanteStimato Float?
  rationale             String?
  stato                 TripStatus @default(pianificato)
  dataPartenza          DateTime?
  dataArrivo            DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  company Company  @relation(fields: [companyId], references: [id])
  driver  Driver   @relation(fields: [driverId], references: [id])
  vehicle Vehicle  @relation(fields: [vehicleId], references: [id])
  orders  Order[]

  @@index([companyId])
  @@index([stato])
}

enum TripStatus {
  pianificato
  approvato
  in_corso
  completato
  annullato
}

model Partner {
  id             String   @id @default(cuid())
  companyId      String
  nome           String
  piva           String?
  indirizzo      String?
  citta          String?
  telefono       String?
  email          String?
  zoneOperative  String[] // array di zone/regioni
  tipiVeicoli    String[] // tipi di veicoli disponibili
  costoPerKm     Float?
  rating         Float    @default(0)
  noteCollaborazione String?
  attivo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Maintenance {
  id          String   @id @default(cuid())
  vehicleId   String
  tipo        String   // ordinaria, straordinaria, revisione
  descrizione String
  costo       Float?
  data        DateTime
  kmAlMomento Int?
  createdAt   DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}

model Setting {
  id        String @id @default(cuid())
  companyId String
  chiave    String
  valore    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, chiave])
}

model ActivityLog {
  id        String   @id @default(cuid())
  companyId String
  tipo      String   // order_created, trip_planned, driver_assigned, etc.
  messaggio String
  dettagli  Json?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([createdAt])
}
