generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== NextAuth Models ==========

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  nome          String?
  cognome       String?
  image         String?
  companyId     String?
  ruolo         String    @default("admin")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company  Company?  @relation(fields: [companyId], references: [id])
  accounts Account[]
  sessions Session[]

  @@index([companyId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ========== Business Models ==========

model Company {
  id                  String   @id @default(cuid())
  nome                String
  indirizzo           String
  citta               String
  cap                 String
  piva                String   @unique
  telefono            String?
  email               String?
  onboardingCompleted          Boolean   @default(false)
  trialEndsAt                  DateTime?
  stripeCustomerId             String?
  stripeSubscriptionId         String?
  subscriptionStatus           String?   // trialing, active, past_due, canceled
  subscriptionCurrentPeriodEnd DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  users       User[]
  drivers     Driver[]
  vehicles    Vehicle[]
  orders      Order[]
  trips       Trip[]
  partners    Partner[]
  settings    Setting[]
  assignments Assignment[]
  agentLogs   AgentLog[]
}

model Driver {
  id                    String       @id @default(cuid())
  companyId             String
  nome                  String
  cognome               String
  codiceFiscale         String       @unique
  patenteTipo           String       // B, C, CE, etc.
  patenteNumero         String
  patenteScadenza       DateTime
  cartaCQC              String?
  cqcScadenza           DateTime?
  cartaCQCTipo          String?      // merci, persone
  adrPatentino          String?      // numero patentino ADR
  adrScadenza           DateTime?
  tachigrafoScadenza    DateTime
  oreGuidaSettimana     Float        @default(0)
  oreGuidaGiorno        Float        @default(0)
  oreRiposoRimanenti    Float        @default(11)
  stato                 DriverStatus @default(disponibile)
  telefono              String?
  latitudine            Float?
  longitudine           Float?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  trips       Trip[]
  assignments Assignment[]

  @@index([companyId])
  @@index([stato])
}

enum DriverStatus {
  disponibile
  in_viaggio
  riposo
  non_disponibile
}

model Vehicle {
  id               String        @id @default(cuid())
  companyId        String
  targa            String        @unique
  tipo             VehicleType
  marca            String
  modello          String
  anno             Int
  capacitaPesoKg   Float
  capacitaVolumeM3 Float
  consumoKmL       Float?        // consumo carburante km/litro
  stato            VehicleStatus @default(disponibile)
  kmAttuali        Int           @default(0)
  classeEuro       String?       // Euro 3, 4, 5, 6, 6E
  pesoComplessivoKg Float?       // PTT - peso totale a terra
  assicurazioneScadenza DateTime?
  bolloScadenza     DateTime?
  prossimaRevisione DateTime?
  prossimaManutenzione DateTime?
  adrAbilitato     Boolean       @default(false)
  adrScadenza      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  trips        Trip[]
  maintenances Maintenance[]
  assignments  Assignment[]

  @@index([companyId])
  @@index([stato])
}

enum VehicleType {
  furgone
  camion
  furgone_frigo
  cisterna
  pianale
}

enum VehicleStatus {
  disponibile
  in_uso
  manutenzione
}

model Order {
  id                 String      @id @default(cuid())
  companyId          String
  codiceOrdine       String      @unique
  mittenteNome       String
  mittenteIndirizzo  String
  mittenteCitta      String
  mittenteCAP        String
  mittenteLat        Float?
  mittenteLng        Float?
  destinatarioNome   String
  destinatarioIndirizzo String
  destinatarioCitta  String
  destinatarioCAP    String
  destinatarioLat    Float?
  destinatarioLng    Float?
  tipoMerce          String
  merceRefrigerata   Boolean     @default(false)
  mercePericolosa    Boolean     @default(false)
  pesoKg             Float
  volumeM3           Float
  urgenza            Urgenza     @default(normale)
  finestraCaricoDa   DateTime
  finestraCaricoA    DateTime
  finestraConsegnaDa DateTime
  finestraConsegnaA  DateTime
  note               String?
  stato              OrderStatus @default(pending)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  tripId      String?
  trip        Trip?        @relation(fields: [tripId], references: [id])
  assignments Assignment[]

  @@index([companyId])
  @@index([stato])
  @@index([urgenza])
}

enum Urgenza {
  normale
  urgente
  programmato
}

enum OrderStatus {
  pending
  assegnato
  in_corso
  completato
  annullato
}

model Trip {
  id                    String     @id @default(cuid())
  companyId             String
  driverId              String
  vehicleId             String
  routeDataJson         Json?
  kmTotali              Float?
  tempoStimatoMinuti    Int?
  costoCarburanteStimato Float?
  rationale             String?
  stato                 TripStatus @default(pianificato)
  dataPartenza          DateTime?
  dataArrivo            DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  company Company  @relation(fields: [companyId], references: [id])
  driver  Driver   @relation(fields: [driverId], references: [id])
  vehicle Vehicle  @relation(fields: [vehicleId], references: [id])
  orders  Order[]

  @@index([companyId])
  @@index([stato])
}

enum TripStatus {
  pianificato
  approvato
  in_corso
  completato
  annullato
}

model Partner {
  id             String   @id @default(cuid())
  companyId      String
  nome           String
  piva           String?
  indirizzo      String?
  citta          String?
  telefono       String?
  email          String?
  zoneOperative  String[] // array di zone/regioni
  tipiVeicoli    String[] // tipi di veicoli disponibili
  costoPerKm     Float?
  rating         Float    @default(0)
  noteCollaborazione String?
  attivo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Maintenance {
  id          String   @id @default(cuid())
  vehicleId   String
  tipo        String   // ordinaria, straordinaria, revisione
  descrizione String
  costo       Float?
  data        DateTime
  kmAlMomento Int?
  createdAt   DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}

model Setting {
  id        String @id @default(cuid())
  companyId String
  chiave    String
  valore    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, chiave])
}

model ActivityLog {
  id        String   @id @default(cuid())
  companyId String
  tipo      String   // order_created, trip_planned, driver_assigned, etc.
  messaggio String
  dettagli  Json?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([createdAt])
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  ip        String?
  userAgent String?
  success   Boolean
  motivo    String?  // es: "magic_link", "token_expired", "rate_limited"
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// ========== Agentic Dispatch Models ==========

enum AssignmentStatus {
  pending
  approved
  rejected
}

model Assignment {
  id              String           @id @default(cuid())
  companyId       String
  orderId         String
  driverId        String
  vehicleId       String
  score           Int
  maxScore        Int
  checks          Json             // Check[]
  motivazione     String
  status          AssignmentStatus @default(pending)
  kmStimati       Float?
  oreStimate      Float?
  costoCarburante Float?
  createdAt       DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([companyId])
  @@index([status])
}

model AgentLog {
  id         String   @id @default(cuid())
  companyId  String
  agentName  String
  toolName   String
  input      Json
  output     Json
  durationMs Int
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([createdAt])
}

// ========== Regulatory Agent Models ==========

model RegulatoryDeadline {
  id              String   @id @default(cuid())
  titolo          String
  data            String   // "1 Luglio 2026", "In vigore", etc.
  descrizione     String
  sanzione        String?
  urgenza         String   // alta, media, bassa
  categoria       String   // scadenza, in_vigore
  fonti           Json     // string[] — URLs o riferimenti normativi
  riferimentoLegale String? // es. "Reg. UE 1054/2020"
  attivo          Boolean  @default(true)
  aggiornatoIl    DateTime @default(now())
  verificatoIl    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([categoria])
  @@index([attivo])
}

model RegulatoryUpdateLog {
  id            String   @id @default(cuid())
  fontiUsate    Json     // string[] — URLs consultate
  scadenzeAggiunte    Int @default(0)
  scadenzeAggiornate  Int @default(0)
  scadenzeRimosse     Int @default(0)
  riepilogoAgente     String // summary dall'agente
  durataMs      Int
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

// ========== Compliance Models ==========

model ComplianceAlert {
  id          String   @id @default(cuid())
  companyId   String
  tipo        String   // scadenza_patente, scadenza_cqc, scadenza_tachigrafo, scadenza_revisione, scadenza_assicurazione, scadenza_bollo, scadenza_adr, ore_guida_limite, euro5_ban, tariffa_sotto_costo
  severity    String   // critico, avviso, info
  entitaTipo  String   // driver, vehicle, order
  entitaId    String
  entitaNome  String   // nome leggibile (es: "Mario Rossi", "AB123CD")
  messaggio   String
  dataScadenza DateTime?
  risolto     Boolean  @default(false)
  risoltoAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([companyId, risolto])
  @@index([severity])
}
